# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres (connection string from Supabase Dashboard > Settings > Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Stripe (optional - for subscription feature)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# iOS app (Capacitor) — see docs/ios-app-store.md
# URL the native shell loads (your live site). Used by capacitor.config.ts.
CAPACITOR_SERVER_URL=https://quranlab.app
# RevenueCat public iOS API key (Apple In-App Purchase). Safe to expose.
NEXT_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
# Shared secret to authenticate the RevenueCat webhook (set the same value in
# the RevenueCat webhook "Authorization" header). Server-side only.
REVENUECAT_WEBHOOK_SECRET=choose-a-long-random-string
